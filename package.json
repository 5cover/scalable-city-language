{
  "name": "scalable-city-language",
  "version": "0.1.0",
  "description": "A geometry toolkit for Cities: Skylines that enables algorithmic generation of city infrastructure.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist dist-test",
    "lint": "eslint src test eslint.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:compile && node --test dist-test/test",
    "test:compile": "tsc -p tsconfig.test.json"
  },
  "keywords": [],
  "author": "5cover",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
