{
  "name": "scalable-city-language",
  "version": "0.1.0",
  "description": "A geometry toolkit for Cities: Skylines that enables algorithmic generation of city infrastructure.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsc -p tsconfig.test.json --incremental && node --test distest/test/*.test.js",
    "prepare": "eslint && node --test && tsc -p tsconfig.build.json --incremental"
  },
  "keywords": [],
  "author": "5cover",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.24.0",
    "fast-xml-parser": "^5.5.5",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0"
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "singleQuote": true,
    "arrowParens": "avoid",
    "bracketSameLine": true,
    "trailingComma": "es5",
    "overrides": [
      {
        "files": "**/*.ts",
        "options": {
          "parser": "typescript"
        }
      },
      {
        "files": [
          "**/*.ts",
          "**/*.tsx",
          "**/*.js",
          "**/*.jsx",
          "**/*.astro",
          "**/*.mjs",
          "**/*.cjs",
          "**/*.css",
          "**/*.sass",
          "**/*.scss"
        ],
        "options": {
          "tabWidth": 4
        }
      }
    ]
  }
}